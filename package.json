{
  "name": "filing-cabinet",
  "version": "6.0.0",
  "description": "Find files based on partial paths",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "bin/cli.js",
    "index.js"
  ],
  "bin": {
    "filing-cabinet": "bin/cli.js"
  },
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "vitest": "vitest",
    "test": "npm run lint && vitest run",
    "test:ci": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-filing-cabinet.git"
  },
  "keywords": [
    "lookup",
    "es6",
    "amd",
    "commonjs",
    "sass",
    "less",
    "stylus",
    "svelte",
    "vue",
    "partial",
    "resolution",
    "paths"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-filing-cabinet/issues"
  },
  "homepage": "https://github.com/dependents/node-filing-cabinet",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "app-module-path": "^2.2.0",
    "commander": "^15.0.0",
    "enhanced-resolve": "^5.24.0",
    "module-definition": "^7.0.0",
    "module-lookup-amd": "^10.0.1",
    "resolve": "^1.22.12",
    "resolve-dependency-path": "^5.0.0",
    "sass-lookup": "^7.0.0",
    "stylus-lookup": "^7.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "globals": "^17.6.0",
    "vitest": "^4.1.9",
    "xo": "^3.0.2"
  }
}
